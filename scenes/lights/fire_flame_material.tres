[resource]
## Turbulent flame tongues that detach from the base flame and rise, curling. emission from a
## narrow box at the flame base. Slower and denser than embers, with a curling lateral velocity.
emission_shape = 3
emission_box_extents = Vector3(6.0, 1.0, 0.0)

direction = Vector3(0.0, -1.0, 0.0)
spread = 18.0

## Light upward gravity (rising hot gas), so tongues accelerate as they climb.
gravity = Vector3(0.0, -22.0, 0.0)

initial_velocity_min = 22.0
initial_velocity_max = 48.0

## Lateral turbulence via velocity randomness + a gentle orbit so tongues curl.
turbulence_enabled = true
turbulence_noise_strength = 4.0
turbulence_noise_scale = 1.6
turbulence_influence_min = 0.1
turbulence_influence_max = 0.4

## Tongues start wide at the base and shrink as they rise and cool.
scale_min = 0.5
scale_max = 1.1
scale_over_velocity_min = 0.0
scale_over_velocity_max = 0.0

color_ramp = SubResource("flame_ramp")
